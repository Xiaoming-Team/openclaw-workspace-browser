<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
  <!-- Highlight.js for code syntax highlighting -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script>hljs.highlightAll();</script>
</head>
<body>
  <div class="breadcrumb-nav">
    <%- breadcrumbItems.join(' <span>›</span> ') %>
  </div>

  <div class="container">
    <% if (showToggle) { %>
    <div class="content-header">
      <button id="toggleBtn" class="toggle-btn" onclick="toggleView()">📄 原文</button>
    </div>
    <% } %>
    <%- content %>
  </div>

  <% if (showToggle) { %>
  <script>
  let showingRendered = true;
  function toggleView() {
    const rendered = document.getElementById('rendered');
    const raw = document.getElementById('raw');
    const btn = document.getElementById('toggleBtn');
    if (showingRendered) {
      rendered.style.display = 'none';
      raw.style.display = 'block';
      btn.textContent = '🎨 渲染';
    } else {
      rendered.style.display = 'block';
      raw.style.display = 'none';
      btn.textContent = '📄 原文';
    }
    showingRendered = !showingRendered;
  }
  </script>
  <% } %>

  <script>
  (function() {
    var currentModal = null;

    window.toggleTableFullscreen = function(btn) {
      var wrapper = btn.closest('.md-table-wrapper');
      var table = wrapper.querySelector('table');
      var cloned = table.cloneNode(true);

      var overlay = document.createElement('div');
      overlay.className = 'table-modal-overlay';

      var controls = document.createElement('div');
      controls.className = 'table-modal-controls';

      var exitBtn = document.createElement('button');
      exitBtn.innerHTML = '✕ 退出';
      exitBtn.onclick = function(e) { e.stopPropagation(); closeModal(); };
      controls.appendChild(exitBtn);

      var container = document.createElement('div');
      container.className = 'table-container';
      container.appendChild(cloned);

      overlay.appendChild(controls);
      overlay.appendChild(container);
      overlay.onclick = function(e) { if (e.target === overlay) closeModal(); };

      document.body.appendChild(overlay);
      document.body.classList.add('table-modal-open');
      currentModal = overlay;
    };

    function closeModal() {
      if (currentModal) {
        currentModal.remove();
        currentModal = null;
        document.body.classList.remove('table-modal-open');
      }
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && currentModal) closeModal();
    });
  })();
  
  function copyToClipboard(text, successMsg) {
    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(text).then(function() {
        showToast(successMsg);
      }).catch(function() {
        fallbackCopy(text, successMsg);
      });
    } else {
      fallbackCopy(text, successMsg);
    }
  }

  function fallbackCopy(text, successMsg) {
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;left:-9999px;top:-9999px;opacity:0;';
    document.body.appendChild(ta);
    ta.select();
    try {
      document.execCommand('copy');
      showToast(successMsg);
    } catch (e) {
      alert('复制失败，请手动复制: ' + text);
    }
    document.body.removeChild(ta);
  }

  window.copyPath = function(path) {
    copyToClipboard(path, '✓ 路径已复制');
  };

  window.copyFileName = function(name) {
    copyToClipboard(name, '✓ 文件名已复制');
  };

  function showToast(msg) {
    const toast = document.createElement('div');
    toast.textContent = msg;
    toast.style.cssText = 'position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:#28a745;color:white;padding:10px 20px;border-radius:4px;z-index:10000;font-size:14px;box-shadow:0 2px 8px rgba(0,0,0,0.2);';
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 2000);
  }
  </script>
</body>
</html>
